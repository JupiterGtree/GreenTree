NEXT_PUBLIC_DEX_URL=https://jup.ag/swap/SOL-AYJ2xXLxNrcJfx7ycgZA6FQnpTSoipdRcCvJPLMadpuJ
NEXT_PUBLIC_SOLSCAN_BASE_URL=https://solscan.io

PURCHASE_MODE=PAUSED

# Foundation-phase lock. Keep false until environmental mission interactions are ready.
ENVIRONMENTAL_MISSIONS_ENABLED=false

FOUNDATION_DIRECT_EMERGENCY_PAUSED=true

